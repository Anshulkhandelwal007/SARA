                    },
                    "sheetName": "Archived Leads",
                    "options": {}
                },
                "id": "add-archived-leads-tab",
                "name": "Add Archived Leads Tab",
                "type": "n8n-nodes-base.googleSheets",
                "typeVersion": 4,
