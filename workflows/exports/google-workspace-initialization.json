    {
      "parameters": {
        "jsCode": "// Check if SARA CRM folder exists\nconst items = $input.all();\nconst folderExists = items.length > 0 && items[0].json.name === 'SARA CRM';\n\nif (folderExists) {\n  return [{\n    json: {\n      folderExists: true,\n      folderId: items[0].json.id,\n      folderName: items[0].json.name\n    }\n  }];\n} else {\n  return [{\n    json: {\n      folderExists: false,\n      folderId: null,\n      folderName: 'SARA CRM'\n    }\n  }];\n}"
      },
      "id": "evaluate-folder-existence",
      "name": "Evaluate Folder Existence",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
