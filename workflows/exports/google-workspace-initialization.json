        "name": "Google Workspace Initialization",
        "description": null,
        "active": false,
        "isArchived": false,
        "nodes": [
            {
                "parameters": {},
                "id": "manual-trigger",
                "name": "Start Initialization",
                "type": "n8n-nodes-base.manualTrigger",
                "typeVersion": 1,
                "position": [
                    240,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "list",
                    "search": "name:SARA CRM",
                    "options": {}
                },
                "id": "check-folder-exists",
                "name": "Check if SARA CRM Folder Exists",
                "type": "n8n-nodes-base.googleDrive",
                "typeVersion": 2,
                "position": [
                    460,
                    300
                ],
                "credentials": {
                    "googleDriveOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "jsCode": "// Check if SARA CRM folder exists\nconst items = $input.all();\nconst folderExists = items.length > 0 && items[0].json.name === 'SARA CRM';\n\nif (folderExists) {\n  return [{\n    json: {\n      folderExists: true,\n      folderId: items[0].json.id,\n      folderName: items[0].json.name\n    }\n  }];\n} else {\n  return [{\n    json: {\n      folderExists: false,\n      folderId: null,\n      folderName: 'SARA CRM'\n    }\n  }];\n}"
                },
                "id": "evaluate-folder-existence",
                "name": "Evaluate Folder Existence",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    680,
                    300
                ]
            },
            {
                "parameters": {
                    "conditions": {
                        "options": {
                            "caseSensitive": true,
                            "leftValue": "",
                            "typeValidation": "strict"
                        },
                        "conditions": [
                            {
                                "id": "folder-exists-condition",
                                "leftValue": "={{ $json.folderExists }}",
                                "rightValue": true,
                                "operator": {
                                    "type": "boolean",
                                    "operation": "true"
                                }
                            }
                        ],
                        "combinator": "and"
                    },
                    "options": {}
                },
                "id": "if-folder-exists",
                "name": "If Folder Exists",
                "type": "n8n-nodes-base.if",
                "typeVersion": 2,
                "position": [
                    900,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "create",
                    "name": "SARA CRM",
                    "mimeType": "application/vnd.google-apps.folder",
                    "options": {}
                },
                "id": "create-folder",
                "name": "Create SARA CRM Folder",
                "type": "n8n-nodes-base.googleDrive",
                "typeVersion": 2,
                "position": [
                    1120,
                    200
                ],
                "credentials": {
                    "googleDriveOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "jsCode": "// Set folder ID from either existing or newly created folder\nconst folderData = $input.all();\nconst folderId = folderData[0].json.folderId || folderData[0].json.id;\n\nreturn [{\n  json: {\n    folderId: folderId,\n    folderName: 'SARA CRM'\n  }\n}];"
                },
                "id": "set-folder-id",
                "name": "Set Folder ID",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    1340,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "list",
                    "search": "name:Lead Master",
                    "folderId": "={{ $json.folderId }}",
                    "options": {}
                },
                "id": "check-spreadsheet-exists",
                "name": "Check if Lead Master Exists",
                "type": "n8n-nodes-base.googleDrive",
                "typeVersion": 2,
                "position": [
                    1560,
                    300
                ],
                "credentials": {
                    "googleDriveOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "jsCode": "// Check if Lead Master spreadsheet exists\nconst items = $input.all();\nconst spreadsheetExists = items.length > 0 && items[0].json.name === 'Lead Master';\n\nif (spreadsheetExists) {\n  return [{\n    json: {\n      spreadsheetExists: true,\n      spreadsheetId: items[0].json.id,\n      spreadsheetName: items[0].json.name,\n      folderId: $('Set Folder ID').first().json.folderId\n    }\n  }];\n} else {\n  return [{\n    json: {\n      spreadsheetExists: false,\n      spreadsheetId: null,\n      spreadsheetName: 'Lead Master',\n      folderId: $('Set Folder ID').first().json.folderId\n    }\n  }];\n}"
                },
                "id": "evaluate-spreadsheet-existence",
                "name": "Evaluate Spreadsheet Existence",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    1780,
                    300
                ]
            },
            {
                "parameters": {
                    "conditions": {
                        "options": {
                            "caseSensitive": true,
                            "leftValue": "",
                            "typeValidation": "strict"
                        },
                        "conditions": [
                            {
                                "id": "spreadsheet-exists-condition",
                                "leftValue": "={{ $json.spreadsheetExists }}",
                                "rightValue": true,
                                "operator": {
                                    "type": "boolean",
                                    "operation": "true"
                                }
                            }
                        ],
                        "combinator": "and"
                    },
                    "options": {}
                },
                "id": "if-spreadsheet-exists",
                "name": "If Spreadsheet Exists",
                "type": "n8n-nodes-base.if",
                "typeVersion": 2,
                "position": [
                    2000,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "create",
                    "name": "Lead Master",
                    "mimeType": "application/vnd.google-apps.spreadsheet",
                    "parents": [
                        "={{ $json.folderId }}"
                    ],
                    "options": {}
                },
                "id": "create-spreadsheet",
                "name": "Create Lead Master Spreadsheet",
                "type": "n8n-nodes-base.googleDrive",
                "typeVersion": 2,
                "position": [
                    2220,
                    200
                ],
                "credentials": {
                    "googleDriveOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "jsCode": "// Set spreadsheet ID from either existing or newly created spreadsheet\nconst spreadsheetData = $input.all();\nconst spreadsheetId = spreadsheetData[0].json.spreadsheetId || spreadsheetData[0].json.id;\nconst folderId = spreadsheetData[0].json.folderId;\n\nreturn [{\n  json: {\n    spreadsheetId: spreadsheetId,\n    spreadsheetName: 'Lead Master',\n    folderId: folderId\n  }\n}];"
                },
                "id": "set-spreadsheet-id",
                "name": "Set Spreadsheet ID",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    2440,
                    300
                ]
            },
            {
                "parameters": {
                    "operation": "add",
                    "sheetId": {
                        "__rl": true,
                        "value": "={{ $json.spreadsheetId }}",
                        "mode": "url",
                        "name": "Google Sheets"
                    },
                    "sheetName": "Active Leads",
                    "options": {}
                },
