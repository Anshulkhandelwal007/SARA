                    2880,
                    200
                ],
                "credentials": {
                    "googleSheetsOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "operation": "add",
                    "sheetId": {
                        "__rl": true,
                        "value": "={{ $json.spreadsheetId }}",
                        "mode": "url",
                        "name": "Google Sheets"
                    },
                    "sheetName": "Follow-up Log",
                    "options": {}
                },
                "id": "add-followup-log-tab",
                "name": "Add Follow-up Log Tab",
                "type": "n8n-nodes-base.googleSheets",
                "typeVersion": 4,
                "position": [
                    3100,
                    200
                ],
                "credentials": {
                    "googleSheetsOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "operation": "update",
                    "sheetId": {
                        "__rl": true,
                        "value": "={{ $('Set Spreadsheet ID').first().json.spreadsheetId }}",
                        "mode": "url",
                        "name": "Google Sheets"
                    },
                    "sheetName": "Active Leads",
                    "range": "A1:Z1",
                    "options": {}
                },
                "id": "populate-active-leads-headers",
                "name": "Populate Active Leads Headers",
                "type": "n8n-nodes-base.googleSheets",
                "typeVersion": 4,
                "position": [
                    3320,
                    200
                ],
                "credentials": {
                    "googleSheetsOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "jsCode": "// Define headers for Active Leads tab\nconst headers = [\n  'Company Name',\n  'Company Website',\n  'First Name',\n  'Last Name',\n  'Email',\n  'Phone',\n  'Mobile',\n  'Title',\n  'Source',\n  'Estimated Value',\n  'Last Modified',\n  'Status',\n  'Priority Score',\n  'Next Follow-up',\n  'Days Overdue'\n];\n\nreturn [{\n  json: {\n    headers: headers,\n    range: 'A1:O1'\n  }\n}];"
                },
                "id": "define-headers",
                "name": "Define Headers",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    3540,
                    200
                ]
            },
            {
                "parameters": {
                    "operation": "update",
                    "sheetId": {
                        "__rl": true,
                        "value": "={{ $('Set Spreadsheet ID').first().json.spreadsheetId }}",
                        "mode": "url",
                        "name": "Google Sheets"
                    },
                    "sheetName": "Active Leads",
                    "range": "={{ $json.range }}",
                    "options": {
                        "cellFormat": "USER_ENTERED"
                    }
                },
                "id": "write-headers",
                "name": "Write Headers",
                "type": "n8n-nodes-base.googleSheets",
                "typeVersion": 4,
                "position": [
                    3760,
                    200
                ],
                "credentials": {
                    "googleSheetsOAuth2Api": {
                        "id": "google-sheets",
                        "name": "Google Sheets"
                    }
                }
            },
            {
                "parameters": {
                    "jsCode": "// Set spreadsheet ID and prepare final result\nconst spreadsheetId = $('Set Spreadsheet ID').first().json.spreadsheetId;\nconst folderId = $('Set Spreadsheet ID').first().json.folderId;\n\nreturn [{\n  json: {\n    success: true,\n    message: 'Google Workspace initialization completed successfully',\n    folderId: folderId,\n    folderName: 'SARA CRM',\n    spreadsheetId: spreadsheetId,\n    spreadsheetName: 'Lead Master',\n    tabs: ['Active Leads', 'Archived Leads', 'Follow-up Log'],\n    initialized: true\n  }\n}];"
                },
                "id": "prepare-final-result",
                "name": "Prepare Final Result",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    3980,
                    300
                ]
            }
        ],
