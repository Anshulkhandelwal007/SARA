        "jsCode": "// Check if Lead Master spreadsheet exists\nconst items = $input.all();\nconst spreadsheetExists = items.length > 0 && items[0].json.name === 'Lead Master';\n\nif (spreadsheetExists) {\n  return [{\n    json: {\n      spreadsheetExists: true,\n      spreadsheetId: items[0].json.id,\n      spreadsheetName: items[0].json.name,\n      folderId: $('Set Folder ID').first().json.folderId\n    }\n  }];\n} else {\n  return [{\n    json: {\n      spreadsheetExists: false,\n      spreadsheetId: null,\n      spreadsheetName: 'Lead Master',\n      folderId: $('Set Folder ID').first().json.folderId\n    }\n  }];\n}"
      },
