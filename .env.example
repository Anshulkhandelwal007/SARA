# PostgreSQL Configuration
POSTGRES_DB=sara_db
POSTGRES_USER=sara_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=sara.admin@gmail.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here
PGADMIN_CONFIG_SERVER_MODE=False

# n8n Configuration
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=your_32_character_encryption_key_here
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password_here
N8N_EDITOR_BASE_URL=/
N8N_TIMEZONE=Asia/Kolkata

# Backend Configuration
BACKEND_APP_NAME=SARA Backend API
BACKEND_APP_VERSION=1.0.0
BACKEND_DEBUG=false
BACKEND_PORT=8000

# Timezone
TZ=Asia/Kolkata
